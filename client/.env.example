# Configuración de la API - OBLIGATORIO
VITE_API_URL=http://localhost:5175

# Título de la página (aparece en la solapa del navegador)
VITE_PAGE_TITLE="Store Hilos - Tienda Online"

# Configuración de la empresa
VITE_COMPANY_NAME="Store Hilos"
VITE_COMPANY_LOGO_URL="http://localhost:5175/logo-store-hilos.svg"
VITE_COMPANY_EMAIL="contacto@storehilos.uy"
VITE_COMPANY_PHONE="+598 94 288 006"

# Configuración de WhatsApp
VITE_WHATSAPP_NUMBER="+59894288006"
VITE_WHATSAPP_MSG="Hola, quiero hacer una consulta sobre sus productos"

# Configuración de Google OAuth (opcional)
VITE_GOOGLE_CLIENT_ID=""

# Configuración de envío
VITE_ENABLE_FREE_SHIPPING=true
VITE_FREE_SHIPPING_THRESHOLD=2000
VITE_SHIPPING_COST=150

# Configuración de auto-refresh para órdenes (en minutos)
VITE_ORDERS_REFRESH_INTERVAL=3
VITE_ENABLE_ORDER_NOTIFICATIONS=true
